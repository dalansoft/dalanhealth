# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=DalanHealth
APP_ENV=development            # development | production
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Database (MongoDB Atlas in production) ───────────────────────────────
# Atlas M0 free tier — see deploy/DEPLOYMENT.md § Database.
# Production example:
#   mongodb+srv://dalan_api:<password>@dalanhealth.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=dalanhealth

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate production secrets:  openssl rand -hex 32   (use DIFFERENT values)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

OTP_DEMO_CODE=123456           # remove/disable in production

# ── CORS ─────────────────────────────────────────────────────────────────
# Production: https://dalanhealth.com,https://www.dalanhealth.com,https://tv.dalanhealth.com,https://admin.dalanhealth.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:19006

# ── Redis (Upstash) ──────────────────────────────────────────────────────
# Upstash console → your database → "rediss://" TLS connection string.
REDIS_URL=

# ── Object storage (Cloudflare R2) ───────────────────────────────────────
# Cloudflare dashboard → R2 → Manage API tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=DalanHealth <info@dalanhealth.com>

# ── Payments ─────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_SECRET_KEY=

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
